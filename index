<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WinWaves</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        header {
            padding: 100px 20px 60px;
            text-align: center;
        }
        .logo {
            font-size: 3em;
            font-weight: 800;
            letter-spacing: -2px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .tagline {
            color: #888;
            margin-top: 16px;
            font-size: 1.2em;
            font-weight: 300;
        }
        main {
            flex: 1;
            max-width: 600px;
            width: 100%;
            margin: 0 auto;
            padding: 20px;
        }
        .intro {
            text-align: center;
            color: #666;
            line-height: 1.8;
            margin-bottom: 60px;
        }
        .links {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .link-card {
            background: #111;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 20px 24px;
            text-decoration: none;
            color: #fff;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .link-card:hover {
            background: #1a1a1a;
            border-color: #333;
            transform: translateX(4px);
        }
        .link-icon {
            font-size: 1.5em;
        }
        .link-text {
            flex: 1;
        }
        .link-title {
            font-weight: 500;
            margin-bottom: 2px;
        }
        .link-desc {
            font-size: 0.85em;
            color: #666;
        }
        .link-arrow {
            color: #444;
        }
        .link-card:hover .link-arrow {
            color: #667eea;
        }
        footer {
            text-align: center;
            padding: 60px 20px;
            color: #444;
            font-size: 0.85em;
        }
    </style>
</head>
<body>
    <header>
        <div class="logo">WinWaves</div>
        <p class="tagline">Simple tools. Clear purpose.</p>
    </header>

    <main>
        <p class="intro">
            A collection of practical web tools.<br>
            Built for learning, productivity, and daily use.
        </p>

        <div class="links">
            <a href="https://spelling.winwaves.top/" class="link-card">
                <span class="link-icon">📝</span>
                <div class="link-text">
                    <div class="link-title">Spelling Practice</div>
                    <div class="link-desc">G4-G12 English vocabulary trainer</div>
                </div>
                <span class="link-arrow">→</span>
            </a>
        </div>
    </main>

    <footer>
        <p>winwaves.top · Work in progress</p>
    </footer>
</body>
</html>
